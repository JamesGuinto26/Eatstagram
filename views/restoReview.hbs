<main class = "resto-container">

    <div class = "resto-top">
        <h1>{{restaurant.name}}</h1>

        <p class = "resto-rating">
            <strong>Restaurant Rating:</strong> 
            <span class = "stars">{{{stars restaurant.rating}}}</span>
        </p>

        <img src="/images/{{restaurant.image}}" 
             alt = "{{restaurant.name}}" 
             class="resto-image">

        <p>{{restaurant.description}}</p>
        <br>
        <p class = "location"><strong>Location:</strong> {{restaurant.location}}</p>
        <p class = "operating-hrs"><strong>Operating Hours:</strong> {{restaurant.operatingHrs}}</p>
    </div>

    <div class = "after-hr">
        <div class = "reviews-header">
            <h2>User Reviews</h2>
            <a href = "/reviews/add/{{restaurant._id}}" class = "add-review-btn">+ Add Review</a>
        </div>

        {{#if reviews.length}}
            {{#each reviews}}
                <div class = "review-card" id = "review-{{this._id}}">
                    <div class = "review-top">

                        <div class = "review-user">
                            <img src = "{{#if this.userId.image}}{{this.userId.image}}{{else}}/images/profile.png{{/if}}" class = "review-avatar">

                            <div class = "review-user-info">
                                <h4 class = "review-username">
                                    <a href="{{#if (eq ../currentUserId this.userId._id)}}/users/profile{{else}}/users/profile/{{this.userId._id}}{{/if}}">{{this.userId.username}}</a>
                                </h4>

                                <div class = "review-info">
                                    <span class = "stars">{{{stars this.rating}}}</span>

                                    <span class = "review-date">
                                        {{formatDate this.reviewDate}} at {{formatTime this.reviewDate}}
                                        {{#if this.editedAt}}
                                            <span class="edited-label">(edited)</span>
                                        {{/if}}
                                    </span>
                                </div>
                            </div>
                        </div>

                        {{#if (eq ../currentUserId this.userId._id)}}
                        <div class = "review-actions">
                            <a href="/reviews/edit/{{this._id}}" class="edit-btn">Edit</a>
                            <a href="/reviews/delete/{{this._id}}" class="delete-btn" onclick = "return confirm('Are you sure you want to delete this review?');">Delete</a>
                        </div>
                        {{/if}}

                    </div>

                    <h3 class="review-title">{{this.title}}</h3>

                    <p class="review-comment">{{this.comment}}</p>

                    {{#if this.media.length}}
                        <div class = "review-media">
                            {{#each this.media}}
                                {{#if (eq this.mediaType "image")}}
                                    <img src="{{this.url}}" class="review-media-img">
                                {{else}}
                                    <video controls class="review-media-video">
                                    <source src="{{this.url}}">
                                    </video>
                                {{/if}}
                            {{/each}}
                        </div>
                    {{/if}}

                    <div class="review-footer">
                        <div class="review-actions-bottom">
                            <form action="/reviews/{{this._id}}/helpful" method="POST">
                                <button type="submit" class="helpful-btn {{#if this.isHelpful}}active{{/if}}">
                                    👍 Helpful ({{this.helpfulCount}})
                                </button>
                            </form>

                            <form action="/reviews/{{this._id}}/unhelpful" method="POST">
                                <button type="submit" class="unhelpful-btn {{#if this.isUnhelpful}}active{{/if}}">
                                    👎 Unhelpful ({{this.unhelpfulCount}})
                                </button>
                            </form>
                        </div>

                        <a href="/reviews/{{this._id}}/comments" class="check-comments-btn">Check Comments</a>
                    </div>
                </div>
            {{/each}}
        {{else}}
            <p class = "no-reviews">No reviews at the moment.</p>
        {{/if}}
    </div>

</main>

